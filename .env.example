# --- Client (Vite; prefixed vars are PUBLIC — never put secrets here) ---
# "mock" runs the deterministic heuristic router ($0); "live" calls the server proxy.
VITE_MODEL_MODE=mock

# --- Server (copy to server/.env; the API key must NEVER reach src/ or the bundle) ---
PORT=8787
FREELLMAPI_BASE_URL=http://127.0.0.1:3001
FREELLMAPI_API_KEY=
FREELLMAPI_MODEL=auto
# Daily decision ceiling. Unset or 0 = UNLIMITED (default) — FreeLLMAPI tokens
# are free, so the proxy does not self-throttle. Set a positive value only to
# deliberately cap a session (e.g. DAILY_CEILING=50 for a demo).
DAILY_CEILING=0
