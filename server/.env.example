# Copy to server/.env — the API key must NEVER reach src/ or the Vite bundle.
# (Mirrors the server section of the root .env.example.)
PORT=8787
FREELLMAPI_BASE_URL=http://127.0.0.1:3001
# Unified key from the FreeLLMAPI dashboard at http://localhost:3001
FREELLMAPI_API_KEY=
FREELLMAPI_MODEL=auto
DAILY_CEILING=200

# --- v2 tiered routing (optional) ------------------------------------------
# "fast" tier — routine decisions + memory-importance scoring.
# Defaults to FREELLMAPI_MODEL (or "auto") when unset.
FREELLMAPI_MODEL_FAST=
# "smart" tier — dialogue, reflection, daily planning.
# Defaults to FREELLMAPI_MODEL (or "auto") when unset.
FREELLMAPI_MODEL_SMART=

# --- v2 embeddings (optional) -----------------------------------------------
# Model for POST /api/embeddings → FreeLLMAPI /v1/embeddings (memory
# retrieval). Defaults to "auto". Embedding calls do NOT count toward
# DAILY_CEILING.
FREELLMAPI_EMBED_MODEL=auto
